{
    "name": "somework/cqrs-example",
    "type": "project",
    "description": "Example Symfony application showcasing somework/cqrs-bundle with a task-management domain.",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "symfony/framework-bundle": "^7.2",
        "symfony/messenger": "^7.2",
